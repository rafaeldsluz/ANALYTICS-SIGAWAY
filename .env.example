# ═══════════════════════════════════════════════════════════════════
#  Sigaway Agent — Configuração de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  NUNCA commite o .env no git
# ═══════════════════════════════════════════════════════════════════

# ── SEGURANÇA (OBRIGATÓRIO) ─────────────────────────────────────────
# Gere a chave com: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=troque-para-uma-chave-aleatoria-de-64-chars

# Credenciais de acesso à interface web
APP_USERNAME=admin
APP_PASSWORD=troque-para-uma-senha-forte

# Segredo compartilhado com o n8n para validar webhooks (HMAC-SHA256)
# Configure o mesmo valor no n8n: Header "X-Webhook-Signature" = HMAC da payload
WEBHOOK_SECRET=

# ── SMTP (E-mail) ───────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=suasenha

# ── Sigaway (screenshot) ────────────────────────────────────────────
SIGAWAY_URL=https://app.sigaway.com.br
SIGAWAY_USER=seu@email.com
SIGAWAY_PASS=suasenha

# E-mail padrão da campanha
EMAIL_SUBJECT=SUA FROTA APRESENTA VEICULOS COM PERFORMANCE REDUZIDA
EMAIL_CC=
EXCEL_PATH=

# URL base para tracking de aberturas/cliques de e-mail
TRACKING_BASE_URL=http://localhost:5000

# ── Brasil.io — Extração de leads por CNAE ─────────────────────────
BRASILIO_TOKEN=

# ── n8n — SDR Agent ────────────────────────────────────────────────
N8N_URL=
N8N_API_KEY=
N8N_WORKFLOW_ID=

# ── WhatsApp — Evolution API ────────────────────────────────────────
WZ_BASE_URL=https://api.seuservidor.com
WZ_API_KEY=sua_api_key_aqui
WZ_INSTANCE=minha-instancia

# ── Servidor ────────────────────────────────────────────────────────
WEB_PORT=5000
# Se usar HTTPS (Nginx/proxy com SSL), mude para "1"
HTTPS_ONLY=0
